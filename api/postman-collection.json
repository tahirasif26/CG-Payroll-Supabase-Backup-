{
  "info": {
    "_postman_id": "cg-payroll-collection-v1",
    "name": "CG Payroll API",
    "description": "Full endpoint surface of the NestJS backend (api/). Auth uses bearer JWT — run **Auth → Login** first; the post-response script stashes `accessToken` / `refreshToken` / `clientId` into the collection variables and every subsequent request inherits the Authorization header.\n\nGlobal collection variables:\n- `baseUrl` — default `http://localhost:3001/api/v1`. Change for staging/prod.\n- `accessToken`, `refreshToken` — set automatically by Login / Refresh.\n- `clientId`, `employeeId`, `payrollSetupId`, `payrollRunId`, `invitationId`, `assetId`, `leaveTypeId`, `leaveRequestId`, `expenseId`, `advanceId`, `loanId`, `divisionId`, `departmentId`, `designationId` — set them manually or paste from prior responses.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3001/api/v1" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "clientId", "value": "" },
    { "key": "employeeId", "value": "" },
    { "key": "payrollSetupId", "value": "" },
    { "key": "payrollRunId", "value": "" },
    { "key": "invitationId", "value": "" },
    { "key": "assetId", "value": "" },
    { "key": "leaveTypeId", "value": "" },
    { "key": "leaveRequestId", "value": "" },
    { "key": "holidayId", "value": "" },
    { "key": "expenseId", "value": "" },
    { "key": "advanceId", "value": "" },
    { "key": "loanId", "value": "" },
    { "key": "divisionId", "value": "" },
    { "key": "departmentId", "value": "" },
    { "key": "designationId", "value": "" },
    { "key": "approvalGroupId", "value": "" },
    { "key": "approvalPolicyId", "value": "" },
    { "key": "approvalDelegationId", "value": "" },
    { "key": "approvalRequestId", "value": "" },
    { "key": "performanceCycleId", "value": "" },
    { "key": "questionnaireId", "value": "" },
    { "key": "assessmentId", "value": "" },

# cg-payroll API — environment variables
# Copy to `.env` and adjust for local development.

NODE_ENV=development
PORT=3001
API_PREFIX=api
API_VERSION=v1

# CORS — comma-separated list of origins permitted to call the API
CORS_ORIGINS=http://localhost:5173,http://localhost:8080
FRONTEND_URL=http://localhost:5173

# Database (matches docker-compose.yml defaults)
DATABASE_URL=postgresql://cgpayroll:cgpayroll@localhost:5432/cgpayroll?schema=public

# JWT — REPLACE THESE with random 64-char strings in any non-dev environment:
#   openssl rand -hex 32
JWT_ACCESS_SECRET=dev-only-access-secret-change-me-min-32-chars-long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=dev-only-refresh-secret-change-me-min-32-chars-long
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# Token TTLs
PASSWORD_RESET_TOKEN_TTL_MIN=60
EMAIL_VERIFICATION_TOKEN_TTL_HOURS=24
INVITATION_TTL_DAYS=7

# Rate limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Mail (Phase 1 uses dev console transport; SMTP/Resend wired in later phase)
MAIL_FROM=no-reply@cgpayroll.local

# Storage (Phase 9)
#   local: writes to STORAGE_LOCAL_ROOT (default ./storage-data)
#   s3:    AWS S3 or MinIO via @aws-sdk/client-s3
STORAGE_DRIVER=local
STORAGE_LOCAL_ROOT=./storage-data
# S3_REGION=us-east-1
# S3_ENDPOINT=http://localhost:9000          # MinIO local
# S3_FORCE_PATH_STYLE=true                   # required for MinIO
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_BUCKET_PREFIX=cg-payroll-
# STORAGE_PUBLIC_BASE_URL=https://cdn.example.com

# Logging
LOG_LEVEL=debug

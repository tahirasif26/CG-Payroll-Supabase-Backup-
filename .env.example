# ConnectHR — environment variables
# Copy to `.env` and fill in. NEVER commit your real .env.

# Lovable Cloud (Supabase) — auto-provisioned
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# Optional: Sentry error monitoring
VITE_SENTRY_DSN=

# cg-payroll NestJS API base URL. When set, the `src/api/` service layer routes
# requests here. Modules not yet ported continue to hit Supabase directly until
# their migration phase lands.
VITE_API_URL=http://localhost:3001/api/v1
